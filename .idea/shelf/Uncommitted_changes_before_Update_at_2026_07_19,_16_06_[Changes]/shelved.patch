+/// Check that a DocType exists in metadata — either synced into the `doctype`
+/// table or provided by a Rust app fixture. Handlers must verify this before
+/// a client-supplied DocType name is used anywhere near SQL.
+async fn doctype_exists(state: &AppState, pool: &orm::DatabasePool, doctype: &str) -> bool {
+    if state
+        .rust_apps
+        .all_doctypes()
+        .iter()
+        .any(|f| f.name == doctype)
+    {
+        return true;
+    }
+    pool.execute_sql(
+        r#"SELECT 1 FROM "doctype" WHERE name = ? LIMIT 1"#,
+        vec![Value::String(doctype.to_string())],
+    )
+    .await
+    .map(|rows| !rows.is_empty())
+    .unwrap_or(false)
+}

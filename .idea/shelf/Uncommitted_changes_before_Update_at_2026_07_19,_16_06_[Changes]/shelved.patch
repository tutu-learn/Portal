+///
+/// Column names are interpolated into SQL text as double-quoted identifiers;
+/// rejecting anything outside this charset prevents breaking out of the
+/// quoting (SQL injection via attacker-controlled filter/field names).
+pub(crate) fn validate_column_name(col: &str) -> std::result::Result<(), RuntimeError> {

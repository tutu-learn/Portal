+/// Validate a SQL column identifier against `[A-Za-z_][A-Za-z0-9_]*`
+/// (same rules as the ORM's filter/write paths).
+fn validate_column_name(col: &str) -> PyResult<()> {
+    let mut chars = col.chars();
+    let valid = matches!(chars.next(), Some(c) if c.is_ascii_alphabetic() || c == '_')
+        && chars.all(|c| c.is_ascii_alphanumeric() || c == '_');

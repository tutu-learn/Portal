+/// Validate a DocType name against `[A-Za-z0-9_ ]+` before it is turned into
+/// a SQL table identifier. Anything else (quotes, tabs, newlines, …) could
+/// break out of the double-quoted identifier it is interpolated into.
+fn validate_doctype(doctype: &str) -> Result<()> {
+    let valid = !doctype.is_empty()
+        && doctype
+            .chars()
+            .all(|c| c.is_ascii_alphanumeric() || c == '_' || c == ' ');
+    if valid {
+        Ok(())
+    } else {
+        Err(RuntimeError::Validation(format!(
+            "invalid doctype name: {:?}",
